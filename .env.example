# 카카오 개발자센터에서 발급한 JavaScript 키
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 사용할 도메인(localhost, 배포 도메인)을 플랫폼에 등록해야 지도가 표시됩니다.
VITE_KAKAO_MAP_KEY=

# Firebase 웹 앱 config (방명록/RSVP) — Firebase 콘솔 → 프로젝트 설정 → 내 앱
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 관리자 모드 비밀번호 (페이지 하단 "관리자 모드" 버튼 → 방명록 글 삭제)
VITE_ADMIN_PASSWORD=
